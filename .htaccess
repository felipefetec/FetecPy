# ============================================================
# Raiz do projeto — redireciona para public/
#
# Necessário em hosts que não permitem configurar DocumentRoot.
# Se o host permite apontar DocumentRoot para public/, este
# arquivo é ignorado e pode ser omitido do upload.
# ============================================================
RewriteEngine On
RewriteCond %{REQUEST_URI} !^/public/
RewriteRule ^(.*)$ public/$1 [L]
