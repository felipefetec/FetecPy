# Banco de dados e logs (gerados em runtime)
data/*.db
data/*.log

# Dependências PHP e JS
vendor/
node_modules/

# Variáveis de ambiente e credenciais de deploy
.env
.env.*
.env.deploy

# Sistemas operacionais
.DS_Store

# Editores de texto
*.swp
.idea/
.vscode/

# Cobertura de testes
coverage/

# Arquivos internos de desenvolvimento (não sobem ao repositório público)
.claude/
CLAUDE.md
PROMPTS.md

# Cache interno do PHPUnit — gerado automaticamente, sem valor para o repo
.phpunit.result.cache
