# ============================================================
# FetecPy — .htaccess de produção (webroot: public/)
# ============================================================

# Impede listagem de diretórios
Options -Indexes

# ----------------------------------------------------------------
# HTTPS obrigatório
# Redireciona HTTP para HTTPS (descomente em produção)
# ----------------------------------------------------------------
# RewriteEngine On
# RewriteCond %{HTTPS} off
# RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

# ----------------------------------------------------------------
# Roteamento SPA + API
# ----------------------------------------------------------------
RewriteEngine On

# Arquivos e diretórios reais → serve diretamente (JS, CSS, imagens, sw.js)
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# API → front controller PHP
RewriteCond %{REQUEST_URI} ^/api/
RewriteRule ^ api/index.php [QSA,L]

# Tudo mais → SPA (index.html)
RewriteRule ^ index.html [L]

# ----------------------------------------------------------------
# Cache de assets estáticos
# Pyodide e outros assets raramente mudam — cache longo
# ----------------------------------------------------------------
<IfModule mod_expires.c>
  ExpiresActive On

  # HTML — sem cache (carrega sempre a versão mais recente)
  ExpiresByType text/html                  "access plus 0 seconds"

  # JavaScript e CSS — cache de 1 semana
  ExpiresByType text/javascript            "access plus 1 week"
  ExpiresByType application/javascript     "access plus 1 week"
  ExpiresByType text/css                   "access plus 1 week"

  # Fontes e imagens — cache de 1 mês
  ExpiresByType font/woff2                 "access plus 1 month"
  ExpiresByType image/svg+xml              "access plus 1 month"
  ExpiresByType image/png                  "access plus 1 month"
  ExpiresByType image/webp                 "access plus 1 month"
</IfModule>

# ----------------------------------------------------------------
# Cabeçalhos de segurança
# ----------------------------------------------------------------
<IfModule mod_headers.c>
  # Impede que a página seja embutida em iframes externos
  Header always set X-Frame-Options "SAMEORIGIN"

  # Força o tipo MIME declarado (evita MIME sniffing)
  Header always set X-Content-Type-Options "nosniff"

  # Permite Service Worker no escopo raiz
  Header always set Service-Worker-Allowed "/"

  # Remove informação do servidor PHP
  Header always unset X-Powered-By
</IfModule>

# ----------------------------------------------------------------
# Proteção de arquivos sensíveis
# ----------------------------------------------------------------

# Bloqueia acesso direto a arquivos de configuração e dados
<FilesMatch "\.(db|sql|log|env|json|lock|md)$">
  Order allow,deny
  Deny from all
</FilesMatch>

# Permite acesso a arquivos JSON da API (exercícios e quizzes não ficam no webroot)
# Nota: exercises/ e content/ ficam FORA de public/ — esta regra é redundante mas segura.
